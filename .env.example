# =============================================================
# CarbonLens — Environment Variables Template
# =============================================================
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your values in .env
#   3. NEVER commit .env to Git (it is in .gitignore)
#
# For production (Cloud Run):
#   - Store GOOGLE_API_KEY in Google Secret Manager
#   - All other vars can be passed via cloudbuild.yaml or
#     gcloud run deploy --set-env-vars
# =============================================================


# ----------------------------------------------------------
# 🔑 Google AI API Key  (REQUIRED)
# Get yours free at: https://aistudio.google.com/apikey
# Supports: Gemini 2.5 Flash (LLM) + gemini-embedding-001 (RAG)
# In Cloud Run: stored in Secret Manager — NOT set here
# ----------------------------------------------------------
GOOGLE_API_KEY=your_google_ai_api_key_here


# ----------------------------------------------------------
# 🤖 Gemini Models
# These are the defaults set in config.py.
# Override here only if you want a different model.
# ----------------------------------------------------------
# GEMINI_LLM_MODEL=gemini-2.5-flash
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001


# ----------------------------------------------------------
# 🌐 CORS
# In development: Vite dev server URL
# In production: your Cloud Run service URL
# ----------------------------------------------------------
CORS_ORIGIN=http://localhost:5173
# CORS_ORIGIN=https://your-service-url.run.app


# ----------------------------------------------------------
# 📁 RAG / ChromaDB
# Path where ChromaDB stores the vector index.
# In Docker/Cloud Run this is set to /app/rag/db via Dockerfile.
# ----------------------------------------------------------
RAG_DB_PATH=./rag/db


# ----------------------------------------------------------
# ⚙️ Application
# ----------------------------------------------------------
APP_ENV=development        # "development" | "production"
LOG_LEVEL=INFO             # "DEBUG" | "INFO" | "WARNING" | "ERROR"


# ----------------------------------------------------------
# ☁️ Cloud Run Deployment (reference only — set via gcloud)
# ----------------------------------------------------------
# PORT=8080                # Cloud Run injects this automatically
# PROJECT_ID=your-gcp-project-id
# REGION=asia-south1

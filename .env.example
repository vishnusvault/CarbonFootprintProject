# =============================================================
# CarbonLens — Environment Variables Template
# =============================================================
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your values in .env
#   3. NEVER commit .env to Git (it is in .gitignore)
#
# For production (Cloud Run):
#   - Store GOOGLE_API_KEY in Google Secret Manager
#   - Pass other vars via: gcloud run deploy --set-env-vars ...
# =============================================================

# ----------------------------------------------------------
# Google AI API Key
# Get yours free at: https://aistudio.google.com/apikey
# In Cloud Run: stored in Secret Manager, NOT here
# ----------------------------------------------------------
GOOGLE_API_KEY=your_google_api_key_here

# ----------------------------------------------------------
# Application
# ----------------------------------------------------------
APP_ENV=development
LOG_LEVEL=INFO

# ----------------------------------------------------------
# RAG / ChromaDB
# ----------------------------------------------------------
RAG_DB_PATH=./rag/db

# ----------------------------------------------------------
# CORS — set to your Cloud Run URL in production
# In development, this is the Vite dev server origin
# ----------------------------------------------------------
CORS_ORIGIN=http://localhost:5173
